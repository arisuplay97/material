{
  "version": 2,
  "outputDirectory": "artifacts/pdam-tracker/dist/public",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "artifacts/api-server/src/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
